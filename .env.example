# ---------------------------------------------------------------------------
# Lifedeck environment variables
# Copy this file to ".env" and fill in the values. Never commit a real ".env".
# ---------------------------------------------------------------------------

# === Required ==============================================================

NODE_ENV=development

# Database (Neon Postgres)
# DATABASE_URL: pooled connection (used by the app at runtime)
# DATABASE_URL_UNPOOLED: direct connection (used by Prisma Migrate)
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/db?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host.region.aws.neon.tech/db?sslmode=require

# Auth - JWT signing secret (generate with: openssl rand -base64 48)
AUTH_SECRET=change-me-with-a-long-random-secret

# Public canonical origin, used for absolute URLs (share/email/OAuth links,
# OpenAPI server). Falls back to VERCEL_URL, then http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Optional (features degrade gracefully when unset) =====================

# Google OAuth sign-in. GOOGLE_REDIRECT_URI defaults to
# "<NEXT_PUBLIC_SITE_URL>/api/v1/auth/google/callback" when omitted, and must
# match an authorized redirect URI in the Google Cloud console.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback

# Email (Resend). Without RESEND_API_KEY, emails are logged to the console.
# EMAIL_FROM must be on a domain verified in Resend (DNS: SPF/DKIM/DMARC),
# otherwise mail is rejected or lands in spam. The default resend.dev sandbox
# domain always lands in spam — verify lifedeck.com.br and set EMAIL_FROM.
# RESEND_API_KEY=
# EMAIL_FROM="Lifedeck <contato@lifedeck.com.br>"

# AI list generation. Resolution order: GEMINI_API_KEY (direct Google Gemini,
# no AI Gateway credits needed) > AI_MODEL (Vercel AI Gateway) > offline stub.
# GEMINI_API_KEY=
# GEMINI_MODEL_ID=gemini-2.5-flash
# AI_MODEL=google/gemini-2.5-flash
# AI_GATEWAY_API_KEY=

# Profile photos (Vercel Blob). Required for avatar uploads; create a Blob store
# in the Vercel dashboard and copy its read/write token. Auto-injected on Vercel.
# BLOB_READ_WRITE_TOKEN=

# Rate limiting (Upstash Redis). Without these, rate limiting is a no-op.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Error monitoring (Sentry). Enabled only when a DSN is set.
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# --- V2 (flag-gated; invisible in production until enabled) ---
# Master switch for all V2 pillars, then per-pillar flags. 'true' enables.
# FEATURES_V2=true
# FEATURE_BILLING=true
# FEATURE_CALENDAR=true
# FEATURE_WHATSAPP=true

# Background job dispatcher (cron). POST /api/v1/internal/dispatch-jobs is
# authorized by `Authorization: Bearer ${CRON_SECRET}`. Without it, cron is denied.
# CRON_SECRET=

# Billing - Asaas (Brazil: Pix, card, boleto). Values are BRL amounts.
# ASAAS_BASE_URL=https://sandbox.asaas.com/api
# ASAAS_API_KEY=
# ASAAS_WEBHOOK_TOKEN=
# ASAAS_VALUE_PRO_MONTHLY=14.90
# ASAAS_VALUE_PRO_ANNUAL=149.00
# ASAAS_VALUE_PREMIUM_MONTHLY=29.90
# ASAAS_VALUE_PREMIUM_ANNUAL=299.00

# Billing - Stripe (international USD). Price IDs come from the Stripe dashboard.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO_MONTHLY=
# STRIPE_PRICE_PRO_ANNUAL=
# STRIPE_PRICE_PREMIUM_MONTHLY=
# STRIPE_PRICE_PREMIUM_ANNUAL=

# Calendar - Google sync (FEATURE_CALENDAR). Reuses GOOGLE_CLIENT_ID/SECRET from
# sign-in; the calendar OAuth callback must be registered in Google Cloud.
# GOOGLE_CALENDAR_REDIRECT_URI=https://lifedeck.com.br/api/v1/calendar/google/callback
# CALENDAR_TOKEN_KEY encrypts stored Google OAuth tokens at rest (AES-256-GCM).
# Without it, tokens are stored as plaintext (acceptable only in local dev).
# CALENDAR_TOKEN_KEY=

# WhatsApp - Meta Cloud API (FEATURE_WHATSAPP). The webhook GET handshake echoes
# hub.challenge when hub.verify_token matches WHATSAPP_VERIFY_TOKEN; POSTs are
# verified against WHATSAPP_APP_SECRET (X-Hub-Signature-256). Outbound sends use
# WHATSAPP_PHONE_NUMBER_ID + WHATSAPP_ACCESS_TOKEN; unset = sends are dropped.
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_APP_SECRET=
# WHATSAPP_VERIFY_TOKEN=
# Proactive reminder alerts use a pre-approved Meta utility template. Unset =
# reminders stay in-app only. Params: [event title, ISO start time].
# WHATSAPP_REMINDER_TEMPLATE=
# WHATSAPP_TEMPLATE_LANGUAGE=pt_BR
# Premium tier routes long text requests to Gemini 3.1 Pro (reuses GEMINI_API_KEY).
# GEMINI_PRO_MODEL_ID=gemini-3-pro-preview
