# ---------------------------------------------------------------------------
# Lifedeck environment variables
# Copy this file to ".env" and fill in the values. Never commit a real ".env".
# ---------------------------------------------------------------------------

# === Required ==============================================================

NODE_ENV=development

# Database (Neon Postgres)
# DATABASE_URL: pooled connection (used by the app at runtime)
# DATABASE_URL_UNPOOLED: direct connection (used by Prisma Migrate)
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/db?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host.region.aws.neon.tech/db?sslmode=require

# Auth - JWT signing secret (generate with: openssl rand -base64 48)
AUTH_SECRET=change-me-with-a-long-random-secret

# Public canonical origin, used for absolute URLs (share/email/OAuth links,
# OpenAPI server). Falls back to VERCEL_URL, then http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Optional (features degrade gracefully when unset) =====================

# Google OAuth sign-in. GOOGLE_REDIRECT_URI defaults to
# "<NEXT_PUBLIC_SITE_URL>/api/v1/auth/google/callback" when omitted, and must
# match an authorized redirect URI in the Google Cloud console.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback

# Email (Resend). Without RESEND_API_KEY, emails are logged to the console.
# EMAIL_FROM must be on a domain verified in Resend (DNS: SPF/DKIM/DMARC),
# otherwise mail is rejected or lands in spam. The default resend.dev sandbox
# domain always lands in spam — verify lifedeck.com.br and set EMAIL_FROM.
# RESEND_API_KEY=
# EMAIL_FROM="Lifedeck <contato@lifedeck.com.br>"

# AI list generation. Resolution order: GEMINI_API_KEY (direct Google Gemini,
# no AI Gateway credits needed) > AI_MODEL (Vercel AI Gateway) > offline stub.
# GEMINI_API_KEY=
# GEMINI_MODEL_ID=gemini-2.5-flash
# AI_MODEL=google/gemini-2.5-flash
# AI_GATEWAY_API_KEY=

# Profile photos (Vercel Blob). Required for avatar uploads; create a Blob store
# in the Vercel dashboard and copy its read/write token. Auto-injected on Vercel.
# BLOB_READ_WRITE_TOKEN=

# Rate limiting (Upstash Redis). Without these, rate limiting is a no-op.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Error monitoring (Sentry). Enabled only when a DSN is set.
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
