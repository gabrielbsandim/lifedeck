{
  "name": "@taskin/infrastructure",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "postinstall": "prisma generate",
    "build": "prisma generate && tsup",
    "dev": "tsup --watch",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "lint": "eslint .",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@neondatabase/serverless": "0.10.4",
    "@prisma/adapter-neon": "6.2.1",
    "@prisma/client": "6.2.1",
    "@taskin/application": "workspace:*",
    "@taskin/domain": "workspace:*",
    "resend": "4.0.1"
  },
  "devDependencies": {
    "@taskin/config": "workspace:*",
    "@vitest/coverage-v8": "2.1.8",
    "eslint": "9.17.0",
    "prisma": "6.2.1",
    "tsup": "8.3.5",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
