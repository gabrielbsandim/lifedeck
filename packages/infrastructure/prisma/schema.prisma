// Lifedeck data model.
// Conventions: Prisma models are PascalCase singular; database tables are
// snake_case plural via @@map; fields are camelCase mapped to snake_case.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum ListType {
  daily
  standalone

  @@map("list_type")
}

enum TaskStatus {
  pending
  completed

  @@map("task_status")
}

enum MemberRole {
  owner
  editor
  viewer

  @@map("member_role")
}

enum Visibility {
  private
  link

  @@map("visibility")
}

model User {
  id            String    @id @default(uuid())
  displayName   String    @map("display_name")
  email         String?   @unique
  passwordHash  String?   @map("password_hash")
  emailVerified DateTime? @map("email_verified")
  isGuest       Boolean   @default(true) @map("is_guest")
  locale        String    @default("en")
  timezone      String    @default("UTC")
  avatarUrl     String?   @map("avatar_url")
  carryOverMode String    @default("manual") @map("carry_over_mode")
  createdAt     DateTime  @default(now()) @map("created_at")

  ownedLists        List[]             @relation("ListOwner")
  memberships       ListMember[]
  assignedTo        Task[]             @relation("TaskAssignee")
  recurringTasks    RecurringTask[]    @relation("RecurringTaskOwner")
  emailVerification EmailVerification?
  notifications     Notification[]
  apiKeys           ApiKey[]
  subscriptions       Subscription[]
  usageEvents         UsageEvent[]
  calendarEvents      CalendarEvent[]
  calendarConnections CalendarConnection[]
  channelIdentities   ChannelIdentity[]

  @@map("users")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String
  data      Json      @default("{}")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("notifications")
}

model ApiKey {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  name         String
  prefix       String
  secretHash   String    @unique @map("secret_hash")
  scopes       String[]
  lastUsedAt   DateTime? @map("last_used_at")
  expiresAt    DateTime? @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("api_keys")
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  codeHash  String   @map("code_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

model List {
  id         String     @id @default(uuid())
  ownerId    String     @map("owner_id")
  title      String
  type       ListType   @default(standalone)
  visibility Visibility @default(private)
  referenceDate DateTime? @map("reference_date") @db.Date
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  owner   User         @relation("ListOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  tasks   Task[]
  members ListMember[]
  shares  ShareLink[]

  @@index([ownerId, createdAt])
  @@map("lists")
}

model Task {
  id              String     @id @default(uuid())
  listId          String     @map("list_id")
  title           String
  status          TaskStatus @default(pending)
  observation     String?
  assigneeId      String?    @map("assignee_id")
  recurringTaskId String?    @map("recurring_task_id")
  isPrivate       Boolean    @default(false) @map("is_private")
  position        Int        @default(0)
  carriedFromDate DateTime?  @map("carried_from_date")
  carriedForwardAt DateTime? @map("carried_forward_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  completedAt     DateTime?  @map("completed_at")

  list      List           @relation(fields: [listId], references: [id], onDelete: Cascade)
  assignee  User?          @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  recurring RecurringTask? @relation(fields: [recurringTaskId], references: [id], onDelete: SetNull)
  subtasks  Subtask[]

  @@unique([listId, recurringTaskId])
  @@index([listId])
  @@index([recurringTaskId])
  @@map("tasks")
}

model Subtask {
  id          String     @id @default(uuid())
  taskId      String     @map("task_id")
  title       String
  status      TaskStatus @default(pending)
  position    Int        @default(0)
  createdAt   DateTime   @default(now()) @map("created_at")
  completedAt DateTime?  @map("completed_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("subtasks")
}

model RecurringTask {
  id        String   @id @default(uuid())
  ownerId   String   @map("owner_id")
  title     String
  rule      Json
  createdAt DateTime @default(now()) @map("created_at")

  owner User   @relation("RecurringTaskOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([ownerId, createdAt])
  @@map("recurring_tasks")
}

model ListMember {
  id      String     @id @default(uuid())
  listId  String     @map("list_id")
  userId  String     @map("user_id")
  role    MemberRole @default(viewer)
  addedAt DateTime   @default(now()) @map("added_at")

  list List @relation(fields: [listId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listId, userId])
  @@map("list_members")
}

model ShareLink {
  id        String   @id @default(uuid())
  listId    String   @map("list_id")
  token     String   @unique
  role      MemberRole @default(viewer)
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  list List @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
  @@map("share_links")
}

model ScheduledJob {
  id        String   @id @default(uuid())
  type      String
  payload   Json     @default("{}")
  runAt     DateTime @map("run_at")
  status    String   @default("pending")
  attempts  Int      @default(0)
  lastError String?  @map("last_error")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([status, runAt])
  @@map("scheduled_jobs")
}

model Subscription {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  plan             String
  status           String
  provider         String
  providerRef      String    @map("provider_ref")
  currentPeriodEnd DateTime? @map("current_period_end")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerRef])
  @@index([userId])
  @@map("subscriptions")
}

model CheckoutIntent {
  id        String   @id @default(uuid())
  provider  String
  reference String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([provider, reference])
  @@map("checkout_intents")
}

model UsageEvent {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  operation String
  credits   Int
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("usage_events")
}

model CalendarEvent {
  id          String   @id @default(uuid())
  ownerId     String   @map("owner_id")
  title       String
  description String?
  location    String?
  startsAt    DateTime @map("starts_at")
  endsAt      DateTime @map("ends_at")
  allDay      Boolean   @default(false) @map("all_day")
  reminders   Int[]     @default([])
  recurrence  Json?
  source      String    @default("local")
  externalId  String?   @map("external_id")
  etag        String?
  syncedAt    DateTime? @map("synced_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @map("updated_at")

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, startsAt])
  @@index([ownerId, externalId])
  @@map("calendar_events")
}

model CalendarConnection {
  id               String    @id @default(uuid())
  ownerId          String    @map("owner_id")
  provider         String
  accessToken      String    @map("access_token")
  refreshToken     String    @map("refresh_token")
  tokenExpiresAt   DateTime  @map("token_expires_at")
  calendarId       String    @default("primary") @map("calendar_id")
  syncToken        String?   @map("sync_token")
  channelId        String?   @map("channel_id")
  resourceId       String?   @map("resource_id")
  channelExpiresAt DateTime? @map("channel_expires_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @map("updated_at")

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, provider])
  @@index([channelId])
  @@map("calendar_connections")
}

model ChannelIdentity {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  channel          String
  address          String?
  targetAddress    String?   @map("target_address")
  pairingCode      String?   @map("pairing_code")
  pairingExpiresAt DateTime? @map("pairing_expires_at")
  verifiedAt       DateTime? @map("verified_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
  @@unique([channel, address])
  @@index([channel, pairingCode])
  @@map("channel_identities")
}
