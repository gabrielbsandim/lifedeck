{
  "name": "lifedeck",
  "version": "0.1.0",
  "private": true,
  "description": "Lifedeck - a shareable, multilingual to-do platform built with clean architecture.",
  "license": "MIT",
  "author": "Gabriel Sandim",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabrielbsandim/lifedeck.git"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run format:check && pnpm run test:coverage",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@commitlint/cli": "19.6.1",
    "@commitlint/config-conventional": "19.6.0",
    "@lifedeck/config": "workspace:*",
    "@types/node": "22.10.2",
    "lint-staged": "15.3.0",
    "prettier": "3.4.2",
    "prettier-plugin-tailwindcss": "0.6.9",
    "simple-git-hooks": "2.11.1",
    "turbo": "2.3.3",
    "typescript": "5.7.2"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "22.10.2"
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-fx2h-pf6j-xcff"
      ]
    }
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "commit-msg": "pnpm exec commitlint --edit \"$1\"",
    "pre-push": "pnpm run typecheck && pnpm run test"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
